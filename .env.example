# Telegram Bot API token from @BotFather
TELEGRAM_API_KEY=

# Yandex AI Studio (Responses API)
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_FOLDER=
# Example: gpt://<folder_id>/yandexgpt/latest
YANDEX_CLOUD_MODEL=

# Vector store with uploaded FAQ (recommended for production)
YANDEX_VECTOR_STORE_ID=

# In-memory dialogue: cleared after this many minutes without a message (default: 60)
# SESSION_TTL_MINUTES=60

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# true = JSON lines to stdout (recommended in Docker); false = plain text
LOG_JSON=true
